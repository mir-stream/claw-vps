#!/usr/bin/env bash
# vm — Firecracker microVM provisioner ("mini VPS" for your homelab)
# Part of claw-vps. See `vm help` and the README for documentation.
set -euo pipefail

VMROOT="/var/lib/vms"
IMAGES="${VMROOT}/images"
KERNEL="${VMROOT}/kernel-claw"
GW="10.42.0.1"
DNS="8.8.8.8"
POOL_FIRST="10.42.0.10"

usage() {
  cat <<'EOF'
vm — Firecracker microVM provisioner ("mini VPS" for your homelab)

One-time host setup:
  vm init                       advertise the Tailscale subnet route and register
                                a client SSH public key (injected into every VM)
  vm setup kernel               build the guest kernel (compiles Linux; takes a while)
  vm setup base                 build the base golden image (debootstrap)

Images (Dockerfile-based; requires docker):
  vm build <image> [-f <Dockerfile>] [--example]
                                build a bootable image on top of claw-vps/base.
                                Default lookup: ./<image>.Dockerfile, then ./Dockerfile
  vm images                     list golden images and the guest kernel

VM lifecycle:
  vm create <name> [--image base] [--cpus 2] [--mem 1024] [--authkey-file <path>]
  vm list                       all VMs: name, IP, state, boot, image, cpu, memory
  vm start <name> / vm stop <name>
  vm restart <name>             restart a running VM (systemctl restart)
  vm status <name>              detailed single-VM view (state, boot, PID, log tail)
  vm destroy <name> [--force]   delete a VM and its disk (asks for confirmation)
  vm logs <name>                follow the VM's serial console (journald)
  vm version / vm help
EOF
}

die() { echo "ERROR: $*" >&2; exit 1; }
need_root() { [ "$(id -u)" -eq 0 ] || die "run with sudo"; }

ip_to_int() { local IFS=. ; read -r a b c d <<<"$1"; echo $(( (a<<24)|(b<<16)|(c<<8)|d )); }
int_to_ip() { echo "$(( ($1>>24)&255 )).$(( ($1>>16)&255 )).$(( ($1>>8)&255 )).$(( $1&255 ))"; }

next_ip() {
  local max; max=$(ip_to_int "${POOL_FIRST}"); max=$((max-1))
  local f cur
  for f in "${VMROOT}"/*/ip; do
    [ -f "$f" ] || continue
    cur=$(ip_to_int "$(cat "$f")")
    [ "$cur" -gt "$max" ] && max=$cur
  done
  int_to_ip $((max+1))
}

mac_for_ip() {  # 10.42.X.Y -> 06:00:0a:2a:XX:YY (locally administered)
  local IFS=. ; read -r a b c d <<<"$1"
  printf '06:00:%02x:%02x:%02x:%02x' "$a" "$b" "$c" "$d"
}

cmd_init() {
  need_root
  echo "[1/3] Advertising Tailscale subnet route (10.42.0.0/16)"
  if command -v tailscale >/dev/null 2>&1; then
    tailscale set --advertise-routes=10.42.0.0/16 && echo "  OK"
  else
    echo "  ! tailscale not found — install it, then run: sudo vm init"
  fi
  echo "[2/3] Registering a client SSH public key (injected into every VM)"
  if [ -s "${VMROOT}/authorized_keys" ]; then
    echo "  $(wc -l < "${VMROOT}/authorized_keys") key(s) already registered. Paste another to add one (empty line to skip):"
  else
    echo "  Paste your public key (on your client: cat ~/.ssh/id_ed25519.pub):"
  fi
  local pubkey; read -r pubkey
  if [ -n "$pubkey" ]; then
    echo "$pubkey" | grep -Eq '^(ssh-|ecdsa-)' || die "that does not look like an SSH public key"
    mkdir -p "${VMROOT}"
    touch "${VMROOT}/authorized_keys"; chmod 644 "${VMROOT}/authorized_keys"
    grep -qxF "$pubkey" "${VMROOT}/authorized_keys" || echo "$pubkey" >> "${VMROOT}/authorized_keys"
    echo "  saved: ${VMROOT}/authorized_keys"
  else
    echo "  skipped"
  fi
  echo "[3/3] One manual step remains:"
  echo "  approve the 10.42.0.0/16 route for this machine at"
  echo "  https://login.tailscale.com/admin/machines (Routing settings)"
  echo ""
  echo "Next: sudo vm setup kernel && sudo vm setup base"
}

# Foundation builds (kernel / base image) live outside the Dockerfile world,
# hence a separate verb from `vm build`.
cmd_setup() {
  need_root
  local target="${1:-}"
  local script="/usr/share/claw-vps/build-${target}.sh"
  { [ -n "$target" ] && [ -f "$script" ]; } || die "usage: vm setup kernel|base"
  exec bash "$script"
}

# Cleans up the loop mount if a Dockerfile build fails midway.
BUILD_MNT=""
_build_cleanup() {
  set +e
  if [ -n "${BUILD_MNT}" ]; then
    mountpoint -q "${BUILD_MNT}" && umount "${BUILD_MNT}"
    rmdir "${BUILD_MNT}" 2>/dev/null
  fi
}

cmd_build() {
  need_root
  local target="${1:-}"; shift || true
  case "$target" in
    kernel|base) die "foundation builds moved to a separate verb  →  sudo vm setup ${target}";;
    "") die "usage: vm build <image-name> [-f <Dockerfile> | --example]";;
  esac

  # Dockerfile build: layer on top of claw-vps/base, convert to a bootable ext4.
  local dockerfile="" use_example=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -f|--file) dockerfile="${2:?missing value for -f}"; shift 2;;
      --example) use_example=1; shift;;
      *) die "unknown option: $1";;
    esac
  done
  echo "$target" | grep -Eq '^[a-z0-9][a-z0-9-]*$' || die "image name must be lowercase letters/digits/hyphens: $target"
  if [ -z "$dockerfile" ]; then
    if [ "$use_example" -eq 1 ]; then
      dockerfile="/usr/share/claw-vps/examples/${target}.Dockerfile"
    elif [ -f "./${target}.Dockerfile" ]; then
      dockerfile="./${target}.Dockerfile"
    elif [ -f "./Dockerfile" ]; then
      dockerfile="./Dockerfile"
    fi
  fi
  { [ -n "$dockerfile" ] && [ -f "$dockerfile" ]; } || die "no Dockerfile found (lookup order: ./${target}.Dockerfile → ./Dockerfile)
  specify one:      vm build ${target} -f <Dockerfile>
  use an example:   vm build ${target} --example   (list: ls /usr/share/claw-vps/examples/)"
  command -v docker >/dev/null 2>&1 || die "docker is required — sudo apt install docker.io"
  [ -f "${IMAGES}/base.ext4" ] || die "base image missing  →  sudo vm setup base"
  echo "==> Dockerfile: ${dockerfile}"

  trap _build_cleanup EXIT

  # 1) base.ext4 → docker base image (claw-vps/base). Re-import when base changes.
  local stamp="${VMROOT}/.base-docker-stamp"
  local cur; cur="$(stat -c %Y "${IMAGES}/base.ext4")"
  if [ "$(cat "$stamp" 2>/dev/null)" != "$cur" ] || ! docker image inspect claw-vps/base >/dev/null 2>&1; then
    echo "==> importing base.ext4 as docker image claw-vps/base"
    BUILD_MNT="$(mktemp -d /mnt/vm-import.XXXX)"
    mount -o loop,ro "${IMAGES}/base.ext4" "${BUILD_MNT}"
    tar -C "${BUILD_MNT}" --numeric-owner -c . | docker import - claw-vps/base >/dev/null
    umount "${BUILD_MNT}"; rmdir "${BUILD_MNT}"; BUILD_MNT=""
    echo "$cur" > "$stamp"
  fi

  # 2) docker build
  docker build -t "claw-vps/${target}" -f "$dockerfile" "$(dirname "$dockerfile")"

  # 3) container export → bootable ext4
  echo "==> converting to ext4 image"
  local cid; cid="$(docker create "claw-vps/${target}" /bin/true)"
  local img="${IMAGES}/${target}.ext4"
  [ -f "$img" ] && mv "$img" "${img}.bak"
  truncate -s 16G "$img"
  mkfs.ext4 -q "$img"
  BUILD_MNT="$(mktemp -d /mnt/vm-export.XXXX)"
  mount -o loop "$img" "${BUILD_MNT}"
  docker export "$cid" | tar -C "${BUILD_MNT}" --numeric-owner -x
  docker rm "$cid" >/dev/null
  rm -f "${BUILD_MNT}/.dockerenv"
  echo "nameserver ${DNS}" > "${BUILD_MNT}/etc/resolv.conf"
  umount "${BUILD_MNT}"; rmdir "${BUILD_MNT}"; BUILD_MNT=""
  trap - EXIT

  echo "==> done: ${img}"
  echo "    use it: sudo vm create <name> --image ${target}"
}

# Cleans up the loop mount and half-built VM dir if create fails midway
# (a leftover ip file would otherwise poison next_ip).
CREATE_DIR=""
CREATE_MNT=""
_create_cleanup() {
  set +e
  if [ -n "${CREATE_MNT}" ]; then
    mountpoint -q "${CREATE_MNT}" && umount "${CREATE_MNT}"
    rmdir "${CREATE_MNT}" 2>/dev/null
  fi
  [ -n "${CREATE_DIR}" ] && rm -rf "${CREATE_DIR}"
}

cmd_create() {
  need_root
  local name="" image="base" cpus=2 mem=1024 authkey_file=""
  name="${1:-}"; shift || true
  case "$name" in ""|--*) die "usage: vm create <name> [--image base] [--cpus N] [--mem MiB] [--authkey-file <path>]";; esac
  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="${2:?missing value for --image}"; shift 2;;
      --cpus) cpus="${2:?missing value for --cpus}"; shift 2;;
      --mem) mem="${2:?missing value for --mem}"; shift 2;;
      --authkey-file) authkey_file="${2:?missing value for --authkey-file}"; shift 2;;
      *) die "unknown option: $1";;
    esac
  done
  echo "$name" | grep -Eq '^[a-z0-9][a-z0-9-]{0,10}$' || die "name must be lowercase letters/digits/hyphens, max 11 chars (tap device limit)"
  echo "$cpus" | grep -Eq '^[0-9]+$' || die "--cpus must be a number: $cpus"
  echo "$mem"  | grep -Eq '^[0-9]+$' || die "--mem must be a number in MiB (e.g. 1024): $mem"
  echo "$image" | grep -Eq '^[a-z0-9-]+$' || die "invalid image name: $image"
  local dir="${VMROOT}/${name}"
  [ -e "$dir" ] && die "already exists: $name"
  if [ ! -f "${IMAGES}/${image}.ext4" ]; then
    [ "$image" = "base" ] && die "image missing: ${IMAGES}/base.ext4  →  sudo vm setup base"
    die "image missing: ${IMAGES}/${image}.ext4  →  sudo vm build ${image}"
  fi
  [ -f "${KERNEL}" ] || die "kernel missing: ${KERNEL}  →  sudo vm setup kernel"

  local ip mac
  ip="$(next_ip)"
  mac="$(mac_for_ip "$ip")"
  CREATE_DIR="$dir"
  trap _create_cleanup EXIT
  mkdir -p "$dir"
  echo "$ip" > "${dir}/ip"
  echo "$image" > "${dir}/image"

  echo "==> copying rootfs (sparse)"
  cp --sparse=always "${IMAGES}/${image}.ext4" "${dir}/rootfs.ext4"

  echo "==> injecting per-VM config (hostname=${name}, ip=${ip})"
  local mnt; mnt="$(mktemp -d /mnt/vm-inject.XXXX)"
  CREATE_MNT="$mnt"
  mount -o loop "${dir}/rootfs.ext4" "$mnt"
  mountpoint -q "$mnt" || die "failed to mount rootfs for injection"
  echo "$name" > "${mnt}/etc/hostname"
  mkdir -p "${mnt}/etc/systemd/network"
  cat > "${mnt}/etc/systemd/network/10-eth0.network" <<EOF
[Match]
Name=eth0

[Network]
Address=${ip}/16
Gateway=${GW}
DNS=${DNS}
EOF
  if [ -n "$authkey_file" ]; then
    [ -f "$authkey_file" ] || { umount "$mnt"; rmdir "$mnt"; die "authkey file not found: $authkey_file"; }
    mkdir -p "${mnt}/etc/vps"
    install -m 600 "$authkey_file" "${mnt}/etc/vps/ts-authkey"
  fi
  # Inject SSH public keys (the access path under the subnet-router model).
  if [ -f "${VMROOT}/authorized_keys" ]; then
    mkdir -p "${mnt}/root/.ssh"
    chmod 700 "${mnt}/root/.ssh"
    install -m 600 "${VMROOT}/authorized_keys" "${mnt}/root/.ssh/authorized_keys"
  fi
  umount "$mnt"; rmdir "$mnt"
  CREATE_MNT=""

  echo "==> writing firecracker config"
  cat > "${dir}/config.json" <<EOF
{
  "boot-source": {
    "kernel_image_path": "${KERNEL}",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off root=/dev/vda rw"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "${dir}/rootfs.ext4",
      "is_root_device": true,
      "is_read_only": false
    }
  ],
  "machine-config": { "vcpu_count": ${cpus}, "mem_size_mib": ${mem} },
  "network-interfaces": [
    { "iface_id": "eth0", "guest_mac": "${mac}", "host_dev_name": "tap-${name}" }
  ]
}
EOF

  echo "==> booting (firecracker@${name})"
  systemctl enable --now "firecracker@${name}.service"
  trap - EXIT
  CREATE_DIR=""
  echo "OK: ${name} (${ip}) — connect: ssh root@${ip} / logs: vm logs ${name}"
}

cmd_list() {
  printf '%-12s %-14s %-10s %-9s %-10s %-4s %s\n' NAME IP STATE BOOT IMAGE CPU MEM
  local d name state boot ip image cpu mem
  for d in "${VMROOT}"/*/; do
    name="$(basename "$d")"
    [ "$name" = "images" ] && continue
    [ -f "${d}/config.json" ] || continue
    ip="$(cat "${d}/ip" 2>/dev/null || echo '?')"
    image="$(cat "${d}/image" 2>/dev/null || echo '?')"
    cpu="$(sed -n 's/.*"vcpu_count": \([0-9]*\).*/\1/p' "${d}/config.json" 2>/dev/null || echo '?')"
    mem="$(sed -n 's/.*"mem_size_mib": \([0-9]*\).*/\1/p' "${d}/config.json" 2>/dev/null || echo '?')"
    state="$(systemctl is-active "firecracker@${name}.service" 2>/dev/null || true)"
    boot="$(systemctl is-enabled "firecracker@${name}.service" 2>/dev/null || true)"
    printf '%-12s %-14s %-10s %-9s %-10s %-4s %s\n' "$name" "$ip" "$state" "${boot:-?}" "$image" "${cpu:-?}" "${mem}MiB"
  done
}

cmd_images() {
  echo "== golden images (${IMAGES}) =="
  ls -lh "${IMAGES}" 2>/dev/null | awk 'NR>1 {print "  " $9 "\t" $5 "\t" $6 " " $7 " " $8}'
  echo "== guest kernel =="
  ls -lh "${KERNEL}" 2>/dev/null | awk '{print "  " $9 "\t" $5 "\t" $6 " " $7 " " $8}' \
    || echo "  (missing — sudo vm setup kernel)"
}

cmd_version() { dpkg-query -W -f='claw-vps ${Version}\n' claw-vps 2>/dev/null || echo "claw-vps (unknown version — not installed via deb?)"; }

_vm_exists() { [ -f "${VMROOT}/${1}/config.json" ] || die "no such VM: ${1}  (see: vm list)"; }

cmd_start()   { need_root; _vm_exists "${1:?name required}"; systemctl reset-failed "firecracker@${1}.service" 2>/dev/null || true; systemctl enable --now "firecracker@${1}.service"; }
cmd_stop()    { need_root; _vm_exists "${1:?name required}"; systemctl disable --now "firecracker@${1}.service"; }
cmd_restart() { need_root; _vm_exists "${1:?name required}"; systemctl reset-failed "firecracker@${1}.service" 2>/dev/null || true; systemctl restart "firecracker@${1}.service"; }

cmd_status() {
  local name="${1:?name required}" dir="${VMROOT}/${1}"
  _vm_exists "$name"
  local ip image vcpus mem boot active sub pid since restarts
  ip="$(cat "${dir}/ip" 2>/dev/null || echo '?')"
  image="$(cat "${dir}/image" 2>/dev/null || echo '?')"
  vcpus="$(sed -n 's/.*"vcpu_count": \([0-9]*\).*/\1/p' "${dir}/config.json" 2>/dev/null || echo '?')"
  mem="$(sed -n 's/.*"mem_size_mib": \([0-9]*\).*/\1/p' "${dir}/config.json" 2>/dev/null || echo '?')"
  boot="$(systemctl is-enabled "firecracker@${name}.service" 2>/dev/null || true)"
  active="$(systemctl is-active "firecracker@${name}.service" 2>/dev/null || true)"
  sub="$(systemctl show -p SubState --value "firecracker@${name}.service" 2>/dev/null || true)"
  pid="$(systemctl show -p MainPID --value "firecracker@${name}.service" 2>/dev/null || true)"
  since="$(systemctl show -p ActiveEnterTimestamp --value "firecracker@${name}.service" 2>/dev/null || true)"
  restarts="$(systemctl show -p NRestarts --value "firecracker@${name}.service" 2>/dev/null || true)"
  # a never-started VM has no runtime state: MainPID=0, timestamp empty — normalize.
  [ "${pid:-}" = "0" ] && pid="-"
  [ -z "${since:-}" ] && since="-"
  [ -z "${restarts:-}" ] && restarts="0"
  printf '%-12s %s\n' name "$name"
  printf '%-12s %s\n' ip "$ip"
  printf '%-12s %s\n' image "$image"
  printf '%-12s %s\n' vcpus "${vcpus:-?}"
  printf '%-12s %s\n' mem "${mem:-?}MiB"
  printf '%-12s %s\n' boot "${boot:-?}"
  printf '%-12s %s (%s)\n' state "${active:-?}" "${sub:-?}"
  printf '%-12s %s\n' pid "${pid:-?}"
  printf '%-12s %s\n' since "${since:-?}"
  printf '%-12s %s\n' restarts "${restarts:-?}"
  echo "recent log:"
  # Same permission gate as cmd_logs, but non-fatal: still print the rest above.
  if [ "$(id -u)" -ne 0 ] && ! id -nG | grep -qwE 'adm|systemd-journal'; then
    echo "  (no permission to read the journal — try: sudo vm status ${name})"
  else
    journalctl -u "firecracker@${name}.service" --no-hostname -n 8 -o cat 2>/dev/null \
      | sed 's/^/  /' || true
  fi
}

cmd_logs() {
  local name="${1:?name required}"
  if [ "$(id -u)" -ne 0 ] && ! id -nG | grep -qwE 'adm|systemd-journal'; then
    die "no permission to read the journal — try: sudo vm logs ${name}"
  fi
  journalctl -u "firecracker@${name}.service" -f --no-hostname
}

cmd_destroy() {
  need_root
  local name="${1:?name required}" force="${2:-}"
  local dir="${VMROOT}/${name}"
  _vm_exists "$name"
  # VMs are pets: destroy is irreversible, so ask the user to re-type the name (--force skips).
  if [ "$force" != "--force" ]; then
    printf 'This permanently deletes VM "%s" including its disk. Type the name to confirm: ' "$name"
    local confirm; read -r confirm
    [ "$confirm" = "$name" ] || die "name mismatch — aborted"
  fi
  systemctl disable --now "firecracker@${name}.service" 2>/dev/null || true
  rm -rf "$dir"
  echo "OK: ${name} destroyed"
}

# Internal hooks called by the systemd template unit.
cmd_net_up() {
  local name="${1:?}"
  ip link show "tap-${name}" >/dev/null 2>&1 || ip tuntap add "tap-${name}" mode tap
  ip link set "tap-${name}" master br0
  # Isolated bridge port: blocks VM<->VM traffic at L2.
  ip link set "tap-${name}" type bridge_slave isolated on
  ip link set "tap-${name}" up
  # Prepare the firecracker API socket path (boot fails if a stale socket exists).
  mkdir -p /run/vps
  rm -f "/run/vps/${name}.sock"
}
cmd_net_down() { ip link del "tap-${1:?}" 2>/dev/null || true; rm -f "/run/vps/${1}.sock"; }

# Attempt a graceful shutdown (called by systemd ExecStop). SendCtrlAltDel is
# x86_64-only; on aarch64 this is a no-op and systemd falls through to SIGTERM.
cmd_send_shutdown() {
  local name="${1:?}" sock="/run/vps/${1:?}.sock"
  [ -S "$sock" ] || return 0
  # -f makes curl fail on HTTP 400, so aarch64 (SendCtrlAltDel unsupported)
  # short-circuits here instead of stalling 10s in the wait loop below.
  curl -fs --unix-socket "$sock" -X PUT "http://localhost/actions" \
    -d '{"action_type": "SendCtrlAltDel"}' >/dev/null 2>&1 || return 0
  # Give the guest up to 10s; the socket disappears when firecracker exits.
  for _ in $(seq 1 10); do
    [ -S "$sock" ] || return 0
    sleep 1
  done
  return 0
}

case "${1:-}" in
  init)     shift; cmd_init "$@";;
  setup)    shift; cmd_setup "$@";;
  build)    shift; cmd_build "$@";;
  create)   shift; cmd_create "$@";;
  list)     shift; cmd_list "$@";;
  images)   shift; cmd_images "$@";;
  start)    shift; cmd_start "$@";;
  stop)     shift; cmd_stop "$@";;
  restart)  shift; cmd_restart "$@";;
  destroy)  shift; cmd_destroy "$@";;
  status)   shift; cmd_status "$@";;
  logs)     shift; cmd_logs "$@";;
  version|--version|-V) cmd_version;;
  net-up)   shift; cmd_net_up "$@";;
  net-down) shift; cmd_net_down "$@";;
  send-shutdown) shift; cmd_send_shutdown "$@";;
  help|--help|-h) usage;;
  *) usage >&2; exit 1;;
esac
