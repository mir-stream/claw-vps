#!/usr/bin/env bash
# clawvps — Firecracker microVM provisioner ("mini VPS" for your homelab)
# Part of claw-vps. See `clawvps help` and the README for documentation.

# VMROOT is overridable so unit tests can point the pure helpers at a temp dir.
VMROOT="${VMROOT:-/var/lib/vms}"
IMAGES="${VMROOT}/images"
KERNEL="${VMROOT}/kernel-claw"
GW="10.42.0.1"
DNS="8.8.8.8"
POOL_FIRST="10.42.0.10"

usage() {
  cat <<'EOF'
clawvps — Firecracker microVM provisioner ("mini VPS" for your homelab)

One-time host setup:
  clawvps init                       advertise the Tailscale subnet route and register
                                a client SSH public key (injected into every VM)
  clawvps setup kernel               build the guest kernel (compiles Linux; takes a while)
  clawvps setup base                 build the base golden image (debootstrap)

Host tuning (memory overcommit):
  clawvps tune [--vm-mem-high auto|<SIZE>] [--swap auto|<SIZE>|off] [--zswap on|off]
                                cap all VMs' RAM (firecracker.slice MemoryHigh),
                                add a host swapfile, and enable zswap — so guests
                                swap before the host does. All default ON.

Images (Dockerfile-based; requires docker):
  clawvps build <image> [-f <Dockerfile>] [--example]
                                build a bootable image on top of claw-vps/base.
                                Default lookup: ./<image>.Dockerfile, then ./Dockerfile
  clawvps images                     list golden images and the guest kernel

VM lifecycle:
  clawvps create <name> [--image base] [--cpus 2] [--mem 1024] [--authkey-file <path>]
  clawvps list                       all VMs: name, IP, state, boot, image, cpu, memory
  clawvps start <name> / clawvps stop <name>
  clawvps restart <name>             restart a running VM (systemctl restart)
  clawvps status <name>              detailed single-VM view (state, boot, PID, log tail)
  clawvps destroy <name> [--force]   delete a VM and its disk (asks for confirmation)
  clawvps logs <name>                follow the VM's serial console (journald)
  clawvps version / clawvps help
EOF
}

die() { echo "ERROR: $*" >&2; exit 1; }
need_root() { [ "$(id -u)" -eq 0 ] || die "run with sudo"; }

ip_to_int() { local IFS=. ; read -r a b c d <<<"$1"; echo $(( (a<<24)|(b<<16)|(c<<8)|d )); }
int_to_ip() { echo "$(( ($1>>24)&255 )).$(( ($1>>16)&255 )).$(( ($1>>8)&255 )).$(( $1&255 ))"; }

next_ip() {
  local max; max=$(ip_to_int "${POOL_FIRST}"); max=$((max-1))
  local f cur
  for f in "${VMROOT}"/*/ip; do
    [ -f "$f" ] || continue
    cur=$(ip_to_int "$(cat "$f")")
    [ "$cur" -gt "$max" ] && max=$cur
  done
  int_to_ip $((max+1))
}

mac_for_ip() {  # 10.42.X.Y -> 06:00:0a:2a:XX:YY (locally administered)
  local IFS=. ; read -r a b c d <<<"$1"
  printf '06:00:%02x:%02x:%02x:%02x' "$a" "$b" "$c" "$d"
}

# ---- pure helpers for `clawvps tune` (no side effects; unit-tested) ----------
# Reserve for the host kernel + userspace + firecracker overhead, so the VMs'
# aggregate MemoryHigh leaves headroom for everything outside the slice.
TUNE_HOST_RESERVE_MIB="${TUNE_HOST_RESERVE_MIB:-2048}"
# Below this the auto MemoryHigh result is too small to be meaningful.
TUNE_MIN_MEM_HIGH_MIB="${TUNE_MIN_MEM_HIGH_MIB:-512}"
# Cap auto swap so we never carve out an absurd swapfile on a big-RAM host.
TUNE_MAX_SWAP_MIB="${TUNE_MAX_SWAP_MIB:-16384}"

# auto_mem_high_mib <total-mib> -> MiB for the VM slice (total - host reserve).
# Prints nothing (and returns 1) when the result is <= 0 or below the floor, so
# the caller can warn and skip rather than set a broken value.
auto_mem_high_mib() {
  local total="${1:?}" v
  v=$(( total - TUNE_HOST_RESERVE_MIB ))
  if [ "$v" -lt "$TUNE_MIN_MEM_HIGH_MIB" ]; then return 1; fi
  echo "$v"
}

# auto_swap_mib <total-mib> -> swap size in MiB = total RAM, capped at the max.
auto_swap_mib() {
  local total="${1:?}"
  if [ "$total" -gt "$TUNE_MAX_SWAP_MIB" ]; then echo "$TUNE_MAX_SWAP_MIB"; else echo "$total"; fi
}

# normalize_size_mib <arg> -> integer MiB. Accepts a bare integer (MiB) or a
# systemd-style suffix: K/M/G/T (binary, MiB-rounded). Returns 1 on garbage.
normalize_size_mib() {
  local in="${1:?}" num unit
  num="${in%[KkMmGgTt]}"
  unit="${in#"$num"}"
  case "$num" in ''|*[!0-9]*) return 1;; esac
  case "$unit" in
    ''|M|m) echo "$num";;
    K|k)    echo $(( num / 1024 ));;
    G|g)    echo $(( num * 1024 ));;
    T|t)    echo $(( num * 1024 * 1024 ));;
    *)      return 1;;
  esac
}

# True once THIS node's 10.42.0.0/16 route is approved & active in the tailnet.
# Scope to the "Self" block: peers carry the CIDR in their AllowedIPs (their route
# *to* us), so a whole-output grep would false-positive before approval.
_route_active() {
  tailscale status --json 2>/dev/null | sed -n '/"Self"/,/"Peer"/p' | grep -q '10\.42\.0\.0/16'
}

# Poll _route_active until it succeeds (return 0) or <timeout> seconds elapse
# (return 1), printing a dot per poll. timeout/interval are overridable so the
# unit tests can drive both outcomes without sleeping. The explicit `if`s keep
# this safe under `set -e` regardless of the caller's context.
_await_route() {
  local timeout="${1:-300}" interval="${2:-3}" waited=0
  while true; do
    if _route_active; then return 0; fi
    if [ "$waited" -ge "$timeout" ]; then return 1; fi
    sleep "$interval"; waited=$((waited + interval)); printf '.'
  done
}

cmd_init() {
  need_root

  # ---- [1/3] subnet route ---------------------------------------------------
  echo "[1/3] Advertise the Tailscale subnet route (10.42.0.0/16)"
  if ! command -v tailscale >/dev/null 2>&1; then
    echo "      ! tailscale not found — it is the access path for every VM." >&2
    echo "      → install:  curl -fsSL https://tailscale.com/install.sh | sh" >&2
    echo "      → docs:     https://tailscale.com/docs/install" >&2
    echo "      → then:     sudo tailscale up && sudo clawvps init" >&2
    exit 1
  fi
  if ! tailscale status --json 2>/dev/null | grep -q '"BackendState": *"Running"'; then
    echo "      ! tailscale is installed but not logged in." >&2
    echo "      → log in:   sudo tailscale up" >&2
    echo "      → then:     sudo clawvps init" >&2
    exit 1
  fi
  tailscale set --advertise-routes=10.42.0.0/16 || die "failed to advertise route (is 'sudo tailscale up' done?)"
  echo "      ✓ route advertised"

  # ---- [2/3] client SSH key -------------------------------------------------
  echo ""
  echo "[2/3] Register a client SSH public key (injected into every VM)"
  echo "      This is the PUBLIC key of the machine you'll SSH *from* (your laptop), not this host."
  echo "      → print it:    cat ~/.ssh/id_ed25519.pub"
  echo "      → no key yet?  ssh-keygen -t ed25519   (then print it as above)"
  if [ -s "${VMROOT}/authorized_keys" ]; then
    echo "      $(wc -l < "${VMROOT}/authorized_keys") key(s) already registered — paste another, or press Enter to skip:"
  else
    echo "      Paste the whole line (starts with 'ssh-ed25519 ...'), or press Enter to skip:"
  fi
  local pubkey; read -r pubkey || true
  if [ -n "$pubkey" ]; then
    echo "$pubkey" | grep -Eq '^(ssh-|ecdsa-)' || die "that does not look like an SSH public key"
    mkdir -p "${VMROOT}"
    touch "${VMROOT}/authorized_keys"; chmod 644 "${VMROOT}/authorized_keys"
    grep -qxF "$pubkey" "${VMROOT}/authorized_keys" || echo "$pubkey" >> "${VMROOT}/authorized_keys"
    echo "      ✓ saved: ${VMROOT}/authorized_keys"
  else
    echo "      • skipped"
  fi

  # ---- [3/3] approve route in admin console, then wait for it to go active ---
  echo ""
  echo "[3/3] Approve the subnet route in the admin console"
  if _route_active; then
    echo "      ✓ already approved and active — nothing to do."
  else
    echo "      1. open    https://login.tailscale.com/admin/machines"
    echo "      2. find    this machine ($(hostname)) in the list"
    echo "      3. menu    click '...' on its row → 'Edit route settings'"
    echo "      4. tick    the 10.42.0.0/16 subnet route checkbox"
    echo "      5. save    click 'Save'"
    echo ""
    printf '      waiting for the route to go active (Ctrl-C to skip)'
    if _await_route; then
      echo ""
      echo "      ✓ route is approved and active — VMs are now reachable."
    else
      echo ""
      echo "      ! still not active after 5 min — approve it (steps above), then re-check with:" >&2
      echo "      → sudo clawvps init      (it will confirm once approved)" >&2
    fi
  fi

  echo ""
  echo "Next: sudo clawvps setup kernel && sudo clawvps setup base"
}

# Total physical RAM in MiB (from /proc/meminfo MemTotal, which is in KiB).
_total_ram_mib() { awk '/^MemTotal:/ {print int($2/1024)}' /proc/meminfo; }

# clawvps tune — make memory overcommit safe & host-prioritized using three
# standard Linux mechanisms (no custom daemons): a firecracker.slice MemoryHigh
# soft cap, a host swapfile, and zswap. All default ON; idempotent; persists
# across reboot via systemd units, /etc/fstab, and a slice drop-in (never GRUB).
cmd_tune() {
  need_root
  local mem_high_arg="auto" swap_arg="auto" zswap_arg="on"
  while [ $# -gt 0 ]; do
    case "$1" in
      --vm-mem-high) mem_high_arg="${2:?missing value for --vm-mem-high}"; shift 2;;
      --swap)        swap_arg="${2:?missing value for --swap}"; shift 2;;
      --zswap)       zswap_arg="${2:?missing value for --zswap}"; shift 2;;
      *) die "unknown option: $1  (usage: clawvps tune [--vm-mem-high auto|<SIZE>] [--swap auto|<SIZE>|off] [--zswap on|off])";;
    esac
  done
  case "$zswap_arg" in on|off) ;; *) die "--zswap must be 'on' or 'off': $zswap_arg";; esac

  local total; total="$(_total_ram_mib)"
  if [ -z "$total" ] || [ "$total" -le 0 ]; then
    die "could not read total RAM from /proc/meminfo"
  fi
  echo "claw-vps host tuning (total RAM: ${total} MiB)"

  # ---- [1/3] firecracker.slice MemoryHigh soft cap --------------------------
  echo ""
  echo "[1/3] VM memory soft cap (firecracker.slice MemoryHigh)"
  local mem_high_mib="" mem_high_summary="skipped"
  if [ "$mem_high_arg" = "auto" ]; then
    if mem_high_mib="$(auto_mem_high_mib "$total")"; then
      echo "      auto = total (${total}M) − ${TUNE_HOST_RESERVE_MIB}M host reserve = ${mem_high_mib}M"
    else
      mem_high_mib=""
      echo "      ! host has too little RAM (${total}M) for an auto cap leaving ${TUNE_HOST_RESERVE_MIB}M for the host." >&2
      echo "      → skipping MemoryHigh — set one explicitly: clawvps tune --vm-mem-high <SIZE>" >&2
    fi
  else
    mem_high_mib="$(normalize_size_mib "$mem_high_arg")" || die "invalid --vm-mem-high size: $mem_high_arg"
    [ "$mem_high_mib" -ge 1 ] || die "--vm-mem-high resolves to ${mem_high_mib}M (too small): $mem_high_arg"
    echo "      explicit = ${mem_high_mib}M"
  fi
  if [ -n "$mem_high_mib" ]; then
    mkdir -p /etc/systemd/system/firecracker.slice.d
    cat > /etc/systemd/system/firecracker.slice.d/10-memoryhigh.conf <<EOF
# Written by 'clawvps tune'. Aggregate soft cap for all firecracker@<name> VMs.
[Slice]
MemoryAccounting=yes
MemoryHigh=${mem_high_mib}M
EOF
    systemctl daemon-reload
    echo "      ✓ MemoryHigh=${mem_high_mib}M applied (drop-in + daemon-reload)"
    echo "      • applies to VMs started after this change — restart running VMs (clawvps restart <name>) to pick up the cap"
    mem_high_summary="${mem_high_mib}M"
  fi

  # ---- [2/3] host swapfile --------------------------------------------------
  echo ""
  echo "[2/3] Host swapfile (gives MemoryHigh somewhere to push cold pages)"
  local swap_summary="off"
  if [ "$swap_arg" = "off" ]; then
    echo "      • skipped (--swap off)"
  else
    local swap_mib
    if [ "$swap_arg" = "auto" ]; then
      swap_mib="$(auto_swap_mib "$total")"
      echo "      auto = total RAM capped at ${TUNE_MAX_SWAP_MIB}M = ${swap_mib}M"
    else
      swap_mib="$(normalize_size_mib "$swap_arg")" || die "invalid --swap size: $swap_arg"
      [ "$swap_mib" -ge 1 ] || die "--swap resolves to ${swap_mib}M (too small): $swap_arg"
      echo "      explicit = ${swap_mib}M"
    fi
    if [ -e /swapfile ]; then
      # Pre-existing file: never recreate/resize. Verify it's a *valid, active*
      # swap before persisting — otherwise we'd land an fstab entry that fails
      # 'swapon -a' at boot. Activate it (ok if already active), then confirm.
      echo "      • /swapfile already exists — leaving it in place (not recreating/resizing)"
      swapon /swapfile 2>/dev/null || true
      if ! swapon --show=NAME --noheadings 2>/dev/null | grep -qx /swapfile; then
        die "/swapfile exists but is not a valid/active swap — refusing to persist it; remove it (rm -f /swapfile) or use --swap off"
      fi
      echo "      ✓ existing /swapfile is active"
      swap_summary="(existing) /swapfile"
    else
      echo "      creating /swapfile (${swap_mib}M)…"
      if ! fallocate -l "${swap_mib}M" /swapfile 2>/dev/null; then
        echo "      (fallocate unsupported on this fs — falling back to dd)"
        dd if=/dev/zero of=/swapfile bs=1M count="$swap_mib" status=none
      fi
      chmod 600 /swapfile
      # Guard mkswap/swapon: on failure, remove the partial file so a re-run
      # starts clean and never persists a landmine in fstab.
      if ! mkswap /swapfile >/dev/null || ! swapon /swapfile; then
        rm -f /swapfile
        die "swap setup failed on this filesystem — /swapfile removed; try --swap off or a different fs"
      fi
      echo "      ✓ swapfile active"
      swap_summary="${swap_mib}M (/swapfile)"
    fi
    # Persist across reboot via fstab (idempotent) — only reached once swap is
    # confirmed active above.
    if ! grep -qE '^[[:space:]]*/swapfile[[:space:]]' /etc/fstab 2>/dev/null; then
      echo "/swapfile none swap sw 0 0" >> /etc/fstab
      echo "      ✓ /etc/fstab entry added"
    else
      echo "      • /etc/fstab already has a /swapfile entry"
    fi
  fi

  # ---- [3/3] zswap (compressed-RAM cache in front of swap) ------------------
  echo ""
  echo "[3/3] zswap (compress reclaimed pages in RAM before hitting the SSD)"
  local zswap_summary="off"
  if [ "$zswap_arg" = "off" ]; then
    echo "      • skipped (--zswap off)"
  else
    if [ ! -d /sys/module/zswap ]; then
      echo "      ! this kernel has no zswap module (/sys/module/zswap absent) — skipping." >&2
      zswap_summary="unavailable"
    else
      # Runtime enable now; persist via a oneshot unit re-applied on boot (no GRUB).
      _zswap_apply
      cat > /etc/systemd/system/claw-zswap.service <<'EOF'
# Written by 'clawvps tune'. Re-applies zswap sysfs settings on every boot
# (zswap reset to defaults at boot since we don't touch the kernel cmdline).
[Unit]
Description=claw-vps: enable zswap (compressed swap cache)
DefaultDependencies=no
After=sysinit.target
Before=swap.target

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/bin/clawvps zswap-apply

[Install]
WantedBy=sysinit.target
EOF
      systemctl daemon-reload
      systemctl enable claw-zswap.service >/dev/null 2>&1 || true
      echo "      ✓ zswap enabled now + claw-zswap.service enabled for boot"
      zswap_summary="on"
    fi
  fi

  # ---- summary --------------------------------------------------------------
  echo ""
  echo "Done. VM memory soft cap: ${mem_high_summary} | swap: ${swap_summary} | zswap: ${zswap_summary}"
  echo "VMs now overcommit safely — under pressure their pages swap (via zswap) before the host's."
}

# Apply zswap settings to sysfs. Each write is guarded because params differ
# across kernels. Called at runtime by cmd_tune and on boot by claw-zswap.service.
_zswap_apply() {
  [ -d /sys/module/zswap ] || return 0
  if [ -w /sys/module/zswap/parameters/enabled ]; then
    echo Y > /sys/module/zswap/parameters/enabled 2>/dev/null || true
  fi
  if [ -w /sys/module/zswap/parameters/compressor ]; then
    echo zstd > /sys/module/zswap/parameters/compressor 2>/dev/null || true
  fi
  if [ -w /sys/module/zswap/parameters/max_pool_percent ]; then
    echo 20 > /sys/module/zswap/parameters/max_pool_percent 2>/dev/null || true
  fi
}

# A colorful heads-up before a long foundation build, so the user knows it is
# expected to take a while (and roughly how long) rather than hung. Honors
# NO_COLOR and falls back to plain text when stdout is not a terminal.
_setup_banner() {
  local target="$1" est what scales
  case "$target" in
    kernel) est="15–40 min"; scales="scales with CPU cores"
            what="Compiling the Firecracker guest kernel from source (linux-6.1.128).";;
    base)   est="5–10 min";  scales="scales with network + disk speed"
            what="Debootstrapping Ubuntu 24.04 and baking the base golden image.";;
    *)      return 0;;
  esac
  local R="" B="" DIM="" CY="" YE="" MAG=""
  if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    R=$'\033[0m'; B=$'\033[1m'; DIM=$'\033[2m'
    CY=$'\033[36m'; YE=$'\033[33m'; MAG=$'\033[35m'
  fi
  local bar="━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  printf '\n%s%s%s\n' "$CY$B" "$bar" "$R"
  printf '%s  ☕  clawvps setup %s%s\n' "$B$MAG" "$target" "$R"
  printf '%s      %s%s\n' "$DIM" "$what" "$R"
  printf '%s      ⏱  estimated time: %s%s   %s(%s; one-time only)%s\n' "$B$YE" "$est" "$R" "$DIM" "$scales" "$R"
  printf '%s      Safe to walk away — build output streams below.%s\n' "$DIM" "$R"
  printf '%s%s%s\n\n' "$CY$B" "$bar" "$R"
}

# Foundation builds (kernel / base image) live outside the Dockerfile world,
# hence a separate verb from `clawvps build`.
cmd_setup() {
  need_root
  local target="${1:-}"
  local script="/usr/share/claw-vps/build-${target}.sh"
  { [ -n "$target" ] && [ -f "$script" ]; } || die "usage: clawvps setup kernel|base"
  _setup_banner "$target"
  exec bash "$script"
}

# Cleans up the loop mount if a Dockerfile build fails midway.
BUILD_MNT=""
_build_cleanup() {
  set +e
  if [ -n "${BUILD_MNT}" ]; then
    mountpoint -q "${BUILD_MNT}" && umount "${BUILD_MNT}"
    rmdir "${BUILD_MNT}" 2>/dev/null
  fi
}

cmd_build() {
  need_root
  local target="${1:-}"; shift || true
  case "$target" in
    kernel|base) die "foundation builds moved to a separate verb  →  sudo clawvps setup ${target}";;
    "") die "usage: clawvps build <image-name> [-f <Dockerfile> | --example]";;
  esac

  # Dockerfile build: layer on top of claw-vps/base, convert to a bootable ext4.
  local dockerfile="" use_example=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -f|--file) dockerfile="${2:?missing value for -f}"; shift 2;;
      --example) use_example=1; shift;;
      *) die "unknown option: $1";;
    esac
  done
  echo "$target" | grep -Eq '^[a-z0-9][a-z0-9-]*$' || die "image name must be lowercase letters/digits/hyphens: $target"
  if [ -z "$dockerfile" ]; then
    if [ "$use_example" -eq 1 ]; then
      dockerfile="/usr/share/claw-vps/examples/${target}.Dockerfile"
    elif [ -f "./${target}.Dockerfile" ]; then
      dockerfile="./${target}.Dockerfile"
    elif [ -f "./Dockerfile" ]; then
      dockerfile="./Dockerfile"
    fi
  fi
  { [ -n "$dockerfile" ] && [ -f "$dockerfile" ]; } || die "no Dockerfile found (lookup order: ./${target}.Dockerfile → ./Dockerfile)
  specify one:      clawvps build ${target} -f <Dockerfile>
  use an example:   clawvps build ${target} --example   (list: ls /usr/share/claw-vps/examples/)"
  command -v docker >/dev/null 2>&1 || die "docker is required — sudo apt install docker.io"
  [ -f "${IMAGES}/base.ext4" ] || die "base image missing  →  sudo clawvps setup base"
  echo "==> Dockerfile: ${dockerfile}"

  trap _build_cleanup EXIT

  # 1) base.ext4 → docker base image (claw-vps/base). Re-import when base changes.
  local stamp="${VMROOT}/.base-docker-stamp"
  local cur; cur="$(stat -c %Y "${IMAGES}/base.ext4")"
  if [ "$(cat "$stamp" 2>/dev/null)" != "$cur" ] || ! docker image inspect claw-vps/base >/dev/null 2>&1; then
    echo "==> importing base.ext4 as docker image claw-vps/base"
    BUILD_MNT="$(mktemp -d /mnt/vm-import.XXXX)"
    mount -o loop,ro "${IMAGES}/base.ext4" "${BUILD_MNT}"
    tar -C "${BUILD_MNT}" --numeric-owner -c . | docker import - claw-vps/base >/dev/null
    umount "${BUILD_MNT}"; rmdir "${BUILD_MNT}"; BUILD_MNT=""
    echo "$cur" > "$stamp"
  fi

  # 2) docker build
  docker build -t "claw-vps/${target}" -f "$dockerfile" "$(dirname "$dockerfile")"

  # 3) container export → bootable ext4
  echo "==> converting to ext4 image"
  local cid; cid="$(docker create "claw-vps/${target}" /bin/true)"
  local img="${IMAGES}/${target}.ext4"
  [ -f "$img" ] && mv "$img" "${img}.bak"
  truncate -s 16G "$img"
  mkfs.ext4 -q "$img"
  BUILD_MNT="$(mktemp -d /mnt/vm-export.XXXX)"
  mount -o loop "$img" "${BUILD_MNT}"
  docker export "$cid" | tar -C "${BUILD_MNT}" --numeric-owner -x
  docker rm "$cid" >/dev/null
  rm -f "${BUILD_MNT}/.dockerenv"
  echo "nameserver ${DNS}" > "${BUILD_MNT}/etc/resolv.conf"
  umount "${BUILD_MNT}"; rmdir "${BUILD_MNT}"; BUILD_MNT=""
  trap - EXIT

  echo "==> done: ${img}"
  echo "    use it: sudo clawvps create <name> --image ${target}"
}

# Cleans up the loop mount and half-built VM dir if create fails midway
# (a leftover ip file would otherwise poison next_ip).
CREATE_DIR=""
CREATE_MNT=""
_create_cleanup() {
  set +e
  if [ -n "${CREATE_MNT}" ]; then
    mountpoint -q "${CREATE_MNT}" && umount "${CREATE_MNT}"
    rmdir "${CREATE_MNT}" 2>/dev/null
  fi
  [ -n "${CREATE_DIR}" ] && rm -rf "${CREATE_DIR}"
}

cmd_create() {
  need_root
  local name="" image="base" cpus=2 mem=1024 authkey_file=""
  name="${1:-}"; shift || true
  case "$name" in ""|--*) die "usage: clawvps create <name> [--image base] [--cpus N] [--mem MiB] [--authkey-file <path>]";; esac
  while [ $# -gt 0 ]; do
    case "$1" in
      --image) image="${2:?missing value for --image}"; shift 2;;
      --cpus) cpus="${2:?missing value for --cpus}"; shift 2;;
      --mem) mem="${2:?missing value for --mem}"; shift 2;;
      --authkey-file) authkey_file="${2:?missing value for --authkey-file}"; shift 2;;
      *) die "unknown option: $1";;
    esac
  done
  echo "$name" | grep -Eq '^[a-z0-9][a-z0-9-]{0,10}$' || die "name must be lowercase letters/digits/hyphens, max 11 chars (tap device limit)"
  echo "$cpus" | grep -Eq '^[0-9]+$' || die "--cpus must be a number: $cpus"
  echo "$mem"  | grep -Eq '^[0-9]+$' || die "--mem must be a number in MiB (e.g. 1024): $mem"
  echo "$image" | grep -Eq '^[a-z0-9-]+$' || die "invalid image name: $image"
  local dir="${VMROOT}/${name}"
  [ -e "$dir" ] && die "already exists: $name"
  if [ ! -f "${IMAGES}/${image}.ext4" ]; then
    [ "$image" = "base" ] && die "image missing: ${IMAGES}/base.ext4  →  sudo clawvps setup base"
    die "image missing: ${IMAGES}/${image}.ext4  →  sudo clawvps build ${image}"
  fi
  [ -f "${KERNEL}" ] || die "kernel missing: ${KERNEL}  →  sudo clawvps setup kernel"

  local ip mac
  ip="$(next_ip)"
  mac="$(mac_for_ip "$ip")"
  CREATE_DIR="$dir"
  trap _create_cleanup EXIT
  mkdir -p "$dir"
  echo "$ip" > "${dir}/ip"
  echo "$image" > "${dir}/image"

  echo "==> copying rootfs (sparse)"
  cp --sparse=always "${IMAGES}/${image}.ext4" "${dir}/rootfs.ext4"

  echo "==> injecting per-VM config (hostname=${name}, ip=${ip})"
  local mnt; mnt="$(mktemp -d /mnt/vm-inject.XXXX)"
  CREATE_MNT="$mnt"
  mount -o loop "${dir}/rootfs.ext4" "$mnt"
  mountpoint -q "$mnt" || die "failed to mount rootfs for injection"
  echo "$name" > "${mnt}/etc/hostname"
  mkdir -p "${mnt}/etc/systemd/network"
  cat > "${mnt}/etc/systemd/network/10-eth0.network" <<EOF
[Match]
Name=eth0

[Network]
Address=${ip}/16
Gateway=${GW}
DNS=${DNS}
EOF
  if [ -n "$authkey_file" ]; then
    [ -f "$authkey_file" ] || { umount "$mnt"; rmdir "$mnt"; die "authkey file not found: $authkey_file"; }
    mkdir -p "${mnt}/etc/vps"
    install -m 600 "$authkey_file" "${mnt}/etc/vps/ts-authkey"
  fi
  # Inject SSH public keys (the access path under the subnet-router model).
  if [ -f "${VMROOT}/authorized_keys" ]; then
    mkdir -p "${mnt}/root/.ssh"
    chmod 700 "${mnt}/root/.ssh"
    install -m 600 "${VMROOT}/authorized_keys" "${mnt}/root/.ssh/authorized_keys"
  fi
  umount "$mnt"; rmdir "$mnt"
  CREATE_MNT=""

  echo "==> writing firecracker config"
  cat > "${dir}/config.json" <<EOF
{
  "boot-source": {
    "kernel_image_path": "${KERNEL}",
    "boot_args": "console=ttyS0 reboot=k panic=1 pci=off root=/dev/vda rw"
  },
  "drives": [
    {
      "drive_id": "rootfs",
      "path_on_host": "${dir}/rootfs.ext4",
      "is_root_device": true,
      "is_read_only": false
    }
  ],
  "machine-config": { "vcpu_count": ${cpus}, "mem_size_mib": ${mem} },
  "network-interfaces": [
    { "iface_id": "eth0", "guest_mac": "${mac}", "host_dev_name": "tap-${name}" }
  ]
}
EOF

  echo "==> booting (firecracker@${name})"
  systemctl enable --now "firecracker@${name}.service"
  trap - EXIT
  CREATE_DIR=""
  echo "OK: ${name} (${ip}) — connect: ssh root@${ip} / logs: clawvps logs ${name}"
}

cmd_list() {
  printf '%-12s %-14s %-10s %-9s %-10s %-4s %s\n' NAME IP STATE BOOT IMAGE CPU MEM
  local d name state boot ip image cpu mem
  for d in "${VMROOT}"/*/; do
    name="$(basename "$d")"
    [ "$name" = "images" ] && continue
    [ -f "${d}/config.json" ] || continue
    ip="$(cat "${d}/ip" 2>/dev/null || echo '?')"
    image="$(cat "${d}/image" 2>/dev/null || echo '?')"
    cpu="$(sed -n 's/.*"vcpu_count": \([0-9]*\).*/\1/p' "${d}/config.json" 2>/dev/null || echo '?')"
    mem="$(sed -n 's/.*"mem_size_mib": \([0-9]*\).*/\1/p' "${d}/config.json" 2>/dev/null || echo '?')"
    state="$(systemctl is-active "firecracker@${name}.service" 2>/dev/null || true)"
    boot="$(systemctl is-enabled "firecracker@${name}.service" 2>/dev/null || true)"
    printf '%-12s %-14s %-10s %-9s %-10s %-4s %s\n' "$name" "$ip" "$state" "${boot:-?}" "$image" "${cpu:-?}" "${mem}MiB"
  done
}

cmd_images() {
  echo "== golden images (${IMAGES}) =="
  ls -lh "${IMAGES}" 2>/dev/null | awk 'NR>1 {print "  " $9 "\t" $5 "\t" $6 " " $7 " " $8}'
  echo "== guest kernel =="
  ls -lh "${KERNEL}" 2>/dev/null | awk '{print "  " $9 "\t" $5 "\t" $6 " " $7 " " $8}' \
    || echo "  (missing — sudo clawvps setup kernel)"
}

cmd_version() { dpkg-query -W -f='claw-vps ${Version}\n' claw-vps 2>/dev/null || echo "claw-vps (unknown version — not installed via deb?)"; }

_vm_exists() { [ -f "${VMROOT}/${1}/config.json" ] || die "no such VM: ${1}  (see: clawvps list)"; }

cmd_start()   { need_root; _vm_exists "${1:?name required}"; systemctl reset-failed "firecracker@${1}.service" 2>/dev/null || true; systemctl enable --now "firecracker@${1}.service"; }
cmd_stop()    { need_root; _vm_exists "${1:?name required}"; systemctl disable --now "firecracker@${1}.service"; }
cmd_restart() { need_root; _vm_exists "${1:?name required}"; systemctl reset-failed "firecracker@${1}.service" 2>/dev/null || true; systemctl restart "firecracker@${1}.service"; }

cmd_status() {
  local name="${1:?name required}" dir="${VMROOT}/${1}"
  _vm_exists "$name"
  local ip image vcpus mem boot active sub pid since restarts
  ip="$(cat "${dir}/ip" 2>/dev/null || echo '?')"
  image="$(cat "${dir}/image" 2>/dev/null || echo '?')"
  vcpus="$(sed -n 's/.*"vcpu_count": \([0-9]*\).*/\1/p' "${dir}/config.json" 2>/dev/null || echo '?')"
  mem="$(sed -n 's/.*"mem_size_mib": \([0-9]*\).*/\1/p' "${dir}/config.json" 2>/dev/null || echo '?')"
  boot="$(systemctl is-enabled "firecracker@${name}.service" 2>/dev/null || true)"
  active="$(systemctl is-active "firecracker@${name}.service" 2>/dev/null || true)"
  sub="$(systemctl show -p SubState --value "firecracker@${name}.service" 2>/dev/null || true)"
  pid="$(systemctl show -p MainPID --value "firecracker@${name}.service" 2>/dev/null || true)"
  since="$(systemctl show -p ActiveEnterTimestamp --value "firecracker@${name}.service" 2>/dev/null || true)"
  restarts="$(systemctl show -p NRestarts --value "firecracker@${name}.service" 2>/dev/null || true)"
  # a never-started VM has no runtime state: MainPID=0, timestamp empty — normalize.
  [ "${pid:-}" = "0" ] && pid="-"
  [ -z "${since:-}" ] && since="-"
  [ -z "${restarts:-}" ] && restarts="0"
  printf '%-12s %s\n' name "$name"
  printf '%-12s %s\n' ip "$ip"
  printf '%-12s %s\n' image "$image"
  printf '%-12s %s\n' vcpus "${vcpus:-?}"
  printf '%-12s %s\n' mem "${mem:-?}MiB"
  printf '%-12s %s\n' boot "${boot:-?}"
  printf '%-12s %s (%s)\n' state "${active:-?}" "${sub:-?}"
  printf '%-12s %s\n' pid "${pid:-?}"
  printf '%-12s %s\n' since "${since:-?}"
  printf '%-12s %s\n' restarts "${restarts:-?}"
  echo "recent log:"
  # Same permission gate as cmd_logs, but non-fatal: still print the rest above.
  if [ "$(id -u)" -ne 0 ] && ! id -nG | grep -qwE 'adm|systemd-journal'; then
    echo "  (no permission to read the journal — try: sudo clawvps status ${name})"
  else
    journalctl -u "firecracker@${name}.service" --no-hostname -n 8 -o cat 2>/dev/null \
      | sed 's/^/  /' || true
  fi
}

cmd_logs() {
  local name="${1:?name required}"
  if [ "$(id -u)" -ne 0 ] && ! id -nG | grep -qwE 'adm|systemd-journal'; then
    die "no permission to read the journal — try: sudo clawvps logs ${name}"
  fi
  journalctl -u "firecracker@${name}.service" -f --no-hostname
}

cmd_destroy() {
  need_root
  local name="${1:?name required}" force="${2:-}"
  local dir="${VMROOT}/${name}"
  _vm_exists "$name"
  # VMs are pets: destroy is irreversible, so ask the user to re-type the name (--force skips).
  if [ "$force" != "--force" ]; then
    printf 'This permanently deletes VM "%s" including its disk. Type the name to confirm: ' "$name"
    local confirm; read -r confirm
    [ "$confirm" = "$name" ] || die "name mismatch — aborted"
  fi
  systemctl disable --now "firecracker@${name}.service" 2>/dev/null || true
  rm -rf "$dir"
  echo "OK: ${name} destroyed"
}

# Internal hooks called by the systemd template unit.
cmd_net_up() {
  local name="${1:?}"
  ip link show "tap-${name}" >/dev/null 2>&1 || ip tuntap add "tap-${name}" mode tap
  ip link set "tap-${name}" master br0
  # Isolated bridge port: blocks VM<->VM traffic at L2.
  ip link set "tap-${name}" type bridge_slave isolated on
  ip link set "tap-${name}" up
  # Prepare the firecracker API socket path (boot fails if a stale socket exists).
  mkdir -p /run/vps
  rm -f "/run/vps/${name}.sock"
}
cmd_net_down() { ip link del "tap-${1:?}" 2>/dev/null || true; rm -f "/run/vps/${1}.sock"; }

# Attempt a graceful shutdown (called by systemd ExecStop). SendCtrlAltDel is
# x86_64-only; on aarch64 this is a no-op and systemd falls through to SIGTERM.
cmd_send_shutdown() {
  local name="${1:?}" sock="/run/vps/${1:?}.sock"
  [ -S "$sock" ] || return 0
  # -f makes curl fail on HTTP 400, so aarch64 (SendCtrlAltDel unsupported)
  # short-circuits here instead of stalling 10s in the wait loop below.
  curl -fs --unix-socket "$sock" -X PUT "http://localhost/actions" \
    -d '{"action_type": "SendCtrlAltDel"}' >/dev/null 2>&1 || return 0
  # Give the guest up to 10s; the socket disappears when firecracker exits.
  for _ in $(seq 1 10); do
    [ -S "$sock" ] || return 0
    sleep 1
  done
  return 0
}

# Dispatch only when executed directly. When sourced (unit tests), just load the
# functions so the pure helpers can be exercised without root or a real host.
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
  set -euo pipefail
  case "${1:-}" in
    init)     shift; cmd_init "$@";;
    tune)     shift; cmd_tune "$@";;
    setup)    shift; cmd_setup "$@";;
    build)    shift; cmd_build "$@";;
    create)   shift; cmd_create "$@";;
    list)     shift; cmd_list "$@";;
    images)   shift; cmd_images "$@";;
    start)    shift; cmd_start "$@";;
    stop)     shift; cmd_stop "$@";;
    restart)  shift; cmd_restart "$@";;
    destroy)  shift; cmd_destroy "$@";;
    status)   shift; cmd_status "$@";;
    logs)     shift; cmd_logs "$@";;
    version|--version|-V) cmd_version;;
    zswap-apply) shift; _zswap_apply;;
    net-up)   shift; cmd_net_up "$@";;
    net-down) shift; cmd_net_down "$@";;
    send-shutdown) shift; cmd_send_shutdown "$@";;
    help|--help|-h) usage;;
    *) usage >&2; exit 1;;
  esac
fi
